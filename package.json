{
  "name": "browzerjs",
  "version": "0.1.0",
  "description": "Better developer experience for modern browser APIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soheilhasanjani/browzerjs.git"
  },
  "bugs": {
    "url": "https://github.com/soheilhasanjani/browzerjs/issues"
  },
  "homepage": "https://github.com/soheilhasanjani/browzerjs#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node test.ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}
